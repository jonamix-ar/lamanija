# Configuración de ejemplo - Copia este archivo como .env.local y ajusta los valores
NODE_ENV=development

# API Backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Base URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# External APIs (reemplaza con tus keys reales)
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
# FACEBOOK_APP_ID=tu-facebook-app-id
# TWITTER_API_KEY=tu-twitter-api-key

# Debug
DEBUG=true
NEXT_PUBLIC_DEBUG=true

# Security (para producción)
# SSL_REDIRECT=true
# FORCE_HTTPS=true